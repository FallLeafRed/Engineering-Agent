from crewai.tools import BaseTool
from pydantic import BaseModel, Field
from typing import Type
import os
from git import Repo

# -------- INPUT SCHEMA --------
class GitPushInput(BaseModel):
    commit_message: str = Field(..., description="Commit message for the changes")
    branch: str = Field(default="main", description="Branch to push to")

# -------- TOOL --------
class GitPushTool(BaseTool):
    name: str = "git_push_tool"
    description: str = "Stages, commits, and pushes code to a predefined Git repository."
    args_schema: Type[BaseModel] = GitPushInput

    # 🔧 CHANGE THIS PATH
    repo_path: str = "/path/to/your/local/repo"

    def _run(self, commit_message: str, branch: str = "main") -> str:
        try:
            # Load repo
            repo = Repo(self.repo_path)

            # Check for changes
            if not repo.is_dirty(untracked_files=True):
                return "No changes to commit."

            # Stage all changes
            repo.git.add(A=True)

            # Commit
            repo.index.commit(commit_message)

            # Push
            origin = repo.remote(name="origin")
            origin.push(branch)

            return f"Successfully pushed to {branch} with message: '{commit_message}'"

        except Exception as e:
            return f"Git push failed: {str(e)}"